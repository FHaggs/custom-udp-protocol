[project]
name = "rtp-http"
version = "0.1.0"
description = "Reliable Transport Protocol over UDP"
readme = "README.md"
requires-python = ">=3.12"
dependencies = []

[project.scripts]
rtp = "rtp.__main__:main"
rtp-scenarios = "rtp.scenarios:main"

[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/rtp"]

[dependency-groups]
dev = [
    "pytest>=8.4.1",
]

[tool.pytest.ini_options]
testpaths = ["tests"]
